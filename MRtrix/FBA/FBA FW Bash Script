############################## Step 7 ###################################
#                    Register FOD images to FOD template                #
#########################################################################

# Register the FOD template to the MNI template, found in TractSeg (MNI_FA_template.nii.gz)
# Download from here (https://github.com/MIC-DKFZ/TractSeg/blob/master/tractseg/resources/MNI_FA_template.nii.gz) to "$ROOTFOLDER/derivatives/MRtrix3_group/template/mni"

# Convert to nii.gz and get the correct strides
mrconvert $ROOTFOLDER/MRtrix3_group/template/wmfod_template.mif $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_bad_strides.nii.gz

mrconvert $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_bad_strides.nii.gz $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template.nii.gz -strides -1,2,3,4

# Get a b0 image
mrconvert $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template.nii.gz $ROOTFOLDER/MRtrix3_group/template/mni/l0image.nii.gz -coord 3 0

# remove nan for flirt
fslmaths $ROOTFOLDER/MRtrix3_group/template/mni/l0image.nii.gz -nan $ROOTFOLDER/MRtrix3_group/template/mni/l0image_no_nan.nii.gz

# flirt
flirt -ref $ROOTFOLDER/MRtrix3_group/template/mni/MNI_FA_template.nii.gz -in $ROOTFOLDER/MRtrix3_group/template/mni/l0image_no_nan.nii.gz -out $ROOTFOLDER/MRtrix3_group/template/mni/l0image_MNI.nii.gz -omat $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_2_MNI.mat -dof 12

# convert to mrtrix readable wrap
transformconvert $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_2_MNI.mat $ROOTFOLDER/MRtrix3_group/template/mni/l0image_no_nan.nii.gz $ROOTFOLDER/MRtrix3_group/template/mni/MNI_FA_template.nii.gz flirt_import $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_2_MNI.txt

# Transform FOD template to MNI space with reorientation of fod
mrtransform -reorient_fod 1 $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template.nii.gz -linear $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_2_MNI.txt -template $ROOTFOLDER/MRtrix3_group/template/mni/MNI_FA_template.nii.gz $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_MNI_reorient.nii.gz

# convert nii.gz to .mif file
mrconvert $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_MNI_reorient.nii.gz $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_MNI_reorient.mif

# generate subject to template warps using the study specific population template

for_each -force -nthreads 8 $ROOTFOLDER/MRtrix3/* : mrregister IN/dwi/wmfod_norm.mif -mask1 IN/dwi/dwi_mask_upsampled.mif $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_MNI_reorient.mif -nl_warp IN/dwi/subject2template_warp.mif IN/dwi/template2subject_warp.mif

############################## Step 8 ###################################
