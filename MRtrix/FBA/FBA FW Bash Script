######################################################################


### The code below requires a 'for loop' to run through each subject. You can consider using the 'for each' command instead if writing a 'for loop' is a hassle. Examples of the 'for each' command can be found in subsequent step.

# Also consider doing Gibbs denoising (using mrdegibbs). Check your diffusion data for ringing artifacts before deciding whether to use it
mkdir -p $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/anat $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap $ROOTFOLDER/tmp

mrconvert -force $ROOTFOLDER/rawdata/sub-${SUB}/dwi/sub-${SUB}_dwi.nii.gz $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/raw_dwi.mif -fslgrad $ROOTFOLDER/rawdata/sub-${SUB}/dwi/sub-${SUB}_dwi.bvec $ROOTFOLDER/rawdata/sub-${SUB}/dwi/sub-${SUB}_dwi.bval

dwidenoise -force -nthreads 8 $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/raw_dwi.mif $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den.mif

# mrdegibbs -force -nthreads 8 $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_denoised.mif $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_denoised_unringed.mif -axes 0,1

# Calculate the residual image (raw_dwi - denoised_dwi) for QC purposes
mrcalc $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/raw_dwi.mif $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den.mif -subtract $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/residual.mif

# Extract the b0 images from the diffusion data acquired in the PA direction
dwiextract -force $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/raw_dwi.mif - -bzero | mrmath -force - mean $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap/mean_b0_PA.mif -axis 3

# Extracts the b0 images for diffusion data acquired in the AP direction
# For the PA_BVEC and PA_BVAL files, they should be in the follwing format (assuming you extract only one volume):
# AP_BVEC: 0 0 0
# AP_BVAL: 0
mrconvert -force $ROOTFOLDER/rawdata/sub-${SUB}/fmap/sub-${SUB}_dir-AP_B0.nii.gz $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap/AP.mif # If the PA map contains only 1 image, you will need to add the option "-coord 3 0"

mrconvert -force $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap/AP.mif -fslgrad /$ROOTFOLDER/rawdata/sub-${SUB}/fmap/sub-${SUB}_dir-AP_B0.bvec $ROOTFOLDER/rawdata/sub-${SUB}/fmap/sub-${SUB}_dir-AP_B0.bval - | mrmath - mean $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap/mean_b0_AP.mif -axis 3

# Concatenates the b0 images from AP and PA directions to create a paired b0 image
mrcat -force $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap/mean_b0_PA.mif $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap/mean_b0_AP.mif -axis 3 $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap/b0_pair.mif

# Removes last volume from DWI image (check if this is necessary, not for all DWI)
mrconvert -force $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den.mif -coord 3 0:123 $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den_dir124.mif

# Runs the dwipreproc command, which is a wrapper for eddy and topup.
# --slm=none for single/multi-shell, linear for single-shell
# nocleanup to keep tmp for motion QC
dwifslpreproc -force -nthreads 8  -scratch $ROOTFOLDER/tmp/${SUB} $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den_dir124.mif $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den_preproc.mif -nocleanup -pe_dir PA -rpe_pair -se_epi $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/fmap/b0_pair.mif -eddy_options " --slm=none --data_is_shelled"

# Performs bias field correction. Needs ANTs to be installed in order to use the "ants" option (use "fsl" otherwise)
dwibiascorrect -force -nthreads 8 -scratch $ROOTFOLDER/tmp/${SUB} ants $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den_preproc.mif $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den_preproc_unbiased.mif -bias $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/bias.mif

# Create a mask for future processing steps
dwi2mask -force $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/dwi_den_preproc_unbiased.mif $ROOTFOLDER/derivatives/MRtrix3/sub-${SUB}/dwi/mask.mif

######################### Step 0.1 Prepcossing #######################
#	                       Check for motion	                    	 #
######################################################################
OUTPUT_FILE="$ROOTFOLDER/derivatives/DTI_motionQC.csv"

# Initialize the CSV file
echo "SubjectID,PercentageOutliers" > $OUTPUT_FILE

# Loop over each subject folder
for dir in $ROOTFOLDER/tmp/*; do
    # Extract the subject ID from the directory name
    SUB=$(basename $dir)
    
    # Change to the subject's tmp directory
    cd $ROOTFOLDER/tmp/$SUB || continue
    totalSlices=$(mrinfo dwi.mif | grep Dimensions | awk '{print $6 * $8}')
    totalOutliers=$(awk '{ for(i=1;i<=NF;i++)sum+=$i } END { print sum }' dwi_post_eddy.eddy_outlier_map)
    percentageOutliers=$(echo "scale=5; ($totalOutliers / $totalSlices * 100)/1" | bc)
    
    # Append the results to the CSV file
    echo "$SUB,$percentageOutliers" >> $OUTPUT_FILE
    
    # Return to the previous directory
    cd $ROOTFOLDER
done

