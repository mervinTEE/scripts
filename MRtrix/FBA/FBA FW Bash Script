##########################################################################

fixelfilter $ROOTFOLDER/MRtrix3_group/template/fd smooth $ROOTFOLDER/MRtrix3_group/template/fd_smooth -matrix $ROOTFOLDER/MRtrix3_group/template/matrix/
fixelfilter $ROOTFOLDER/MRtrix3_group/template/log_fc smooth $ROOTFOLDER/MRtrix3_group/template/log_fc_smooth -matrix $ROOTFOLDER/MRtrix3_group/template/matrix/
