# mrview wmfod_template_MNI_reorient.mif and then load the reduced .tck file

############################## Step 17 ###################################
#                Reduce biases in tractogram densities                   #
##########################################################################

tcksift $ROOTFOLDER/MRtrix3_group/template/tracks_20_million.tck $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_MNI_reorient.mif $ROOTFOLDER/MRtrix3_group/template/tracks_2_million_sift.tck -term_number 2000000

############################## Step 18 ###################################
#                Generate fixel-fixel connectivity matrix                #
##########################################################################

fixelconnectivity $ROOTFOLDER/MRtrix3_group/template/mni/fixel_mask/ $ROOTFOLDER/MRtrix3_group/template/tracks_2_million_sift.tck $ROOTFOLDER/MRtrix3_group/template/matrix/

############################## Step 19 ###################################
