#########################################################################

# transform brain mask to MNI space
for_each -force -nthreads 8 $ROOTFOLDER/MRtrix3/* : mrtransform IN/dwi/dwi_mask_upsampled.mif -warp IN/dwi/subject2template_warp.mif -interp nearest -datatype bit IN/dwi/dwi_mask_in_template_space.mif

# average masks to obtain a study-specific template mask
mrmath $ROOTFOLDER/MRtrix3/*/dwi/dwi_mask_in_template_space.mif min $ROOTFOLDER/MRtrix3_group/template/mni/template_mask.mif -datatype bit


############################## Step 9 ###################################
#       Compute a white matter template analysis fixel mask             #
#########################################################################

# Compute a white matter template analysis fixel mask
fod2fixel -mask $ROOTFOLDER/MRtrix3_group/template/mni/template_mask.mif -fmls_peak_value 0.06 $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_MNI_reorient.mif $ROOTFOLDER/MRtrix3_group/template/mni/fixel_mask


############################## Step 10 ##################################
#                Warp FOD images to template space                       #
##########################################################################

for_each -force -nthreads 8 $ROOTFOLDER/MRtrix3/* : mrtransform IN/dwi/wmfod_norm.mif -warp IN/dwi/subject2template_warp.mif -reorient_fod no IN/dwi/fod_in_template_space_NOT_REORIENTED.mif

############################## Step 11 ###################################
#  Segment FOD images to estimate fixels and apparent fibre density (FD) #
##########################################################################
for_each -force -nthreads 8 $ROOTFOLDER/MRtrix3/* : fod2fixel -mask $ROOTFOLDER/MRtrix3_group/template/mni/template_mask.mif IN/dwi/fod_in_template_space_NOT_REORIENTED.mif IN/dwi/fixel_in_template_space_NOT_REORIENTED -afd fd.mif

############################## Step 12 ###################################
#                                Reorient fixels                         #
##########################################################################

for_each -force -nthreads 8 $ROOTFOLDER/MRtrix3/* : fixelreorient IN/dwi/fixel_in_template_space_NOT_REORIENTED IN/dwi/subject2template_warp.mif IN/dwi/fixel_in_template_space

############################## Step 13 ###################################
#                Assign subject fixels to template fixels 			     #
##########################################################################

for_each -force $ROOTFOLDER/MRtrix3/* : fixelcorrespondence IN/dwi/fixel_in_template_space/fd.mif $ROOTFOLDER/MRtrix3_group/template/mni/fixel_mask $ROOTFOLDER/MRtrix3_group/template/fd PRE.mif

############################## Step 14 ###################################
#                Compute the fibre cross-section (FC) metric 			 #
##########################################################################

for_each -force $ROOTFOLDER/MRtrix3/* : warp2metric IN/dwi/subject2template_warp.mif -fc $ROOTFOLDER/MRtrix3_group/template/mni/fixel_mask $ROOTFOLDER/MRtrix3_group/template/fc NAME.mif

# Calculate log(FC)

mkdir $ROOTFOLDER/MRtrix3_group/template/log_fc
cp $ROOTFOLDER/MRtrix3_group/template/fc/index.mif $ROOTFOLDER/MRtrix3_group/template/fc/directions.mif $ROOTFOLDER/MRtrix3_group/template/log_fc
for_each -force $ROOTFOLDER/MRtrix3/* : mrcalc $ROOTFOLDER/MRtrix3_group/template/fc/NAME.mif -log $ROOTFOLDER/MRtrix3_group/template/log_fc/NAME.mif

############################## Step 15 ###################################
#          Compute the fibre density and cross-section (FDC) metric      #
##########################################################################

mkdir $ROOTFOLDER/MRtrix3_group/template/fdc
cp $ROOTFOLDER/MRtrix3_group/template/fc/index.mif $ROOTFOLDER/MRtrix3_group/template/fdc
cp $ROOTFOLDER/MRtrix3_group/template/fc/directions.mif $ROOTFOLDER/MRtrix3_group/template/fdc
for_each -force $ROOTFOLDER/MRtrix3/* : mrcalc $ROOTFOLDER/MRtrix3_group/template/fd/NAME.mif $ROOTFOLDER/MRtrix3_group/template/fc/NAME.mif -mult $ROOTFOLDER/MRtrix3_group/template/fdc/NAME.mif

############################## Step 16 ###################################
#         Perform whole-brain fibre tractography on the FOD template     #
##########################################################################

tckgen -angle 22.5 -maxlen 250 -minlen 10 -power 1.0 $ROOTFOLDER/MRtrix3_group/template/mni/wmfod_template_MNI_reorient.mif -seed_image $ROOTFOLDER/MRtrix3_group/template/mni/template_mask.mif -mask $ROOTFOLDER/MRtrix3_group/template/mni/template_mask.mif -select 20000000 -cutoff 0.06 $ROOTFOLDER/MRtrix3_group/template/tracks_20_million.tck

### check the streamlines
